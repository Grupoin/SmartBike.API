<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBike_Mobile.Views.DashboardPage"
             Title="Mi Impacto Ambiental">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <Label Grid.Row="0" Text="{Binding Saludo}" FontSize="20" FontAttributes="Bold"/>

        <Frame Grid.Row="1" BackgroundColor="#2E4053" CornerRadius="15" Margin="0,20">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="Total CO₂ Evitado" TextColor="#BDC3C7" HorizontalOptions="Center"/>
                <Label Text="{Binding TotalCo2, StringFormat='{0:F2} kg'}" 
                       TextColor="#2ECC71" FontSize="40" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Frame>

        <Button Grid.Row="2" Text="Cerrar Sesión" Command="{Binding CerrarSesionCommand}" BackgroundColor="#E74C3C"/>
    </Grid>
</ContentPage>